{% extends 'templates/page.twig' %}

{% block title %}Акции - Aspro{% endblock %}

{% block page_title %}Каталог{% endblock %}

{% set page_class = "catalog-page" %}

{% block page_content %}
    <div class="fast-catalog is-page">
        <div class="fast-catalog__row">
            {% for item in 1..20 %}
                <div class="fast-catalog__col">
                    <img src="https://premier-demo.ru/upload/resize_cache/iblock/79e/108_108_0/wuy5uh0kcnk6gcgcwkz5l2w41rvmk4h5.jpg"
                         class="fast-catalog__img" alt="">

                    <div>
                        <a href="" class="fast-catalog__title">Смартфоны</a>

                        <div class="fast-catalog__list fast-catalog-list js-fast-catalog__list">
                            {% for item in [
                                'Отделочные материалы техника',
                                'Мужская одежда',
                                'Детская одежда',
                                'Женская одежда',
                                'Мужская одежда',
                                'Мужская одежда',
                                'Детская одежда',
                                'Женская одежда',
                                'Мужская одежда',
                            ] %}
                                <div class="fast-catalog-list__item">
                                    <a href="" class="fast-catalog-list__link js-fast-catalog__link">
                                    <span class="fast-catalog-list__text">
                                        {{ item }}
                                    </span>

                                        <span class="fast-catalog-list__icon js-fast-catalog__show-more-submenu">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="8" height="5"
                                             viewBox="0 0 8 5" fill="none">
                                            <path d="M7 1L4 4L1 1" stroke-width="1.3" stroke-linecap="round"
                                                  stroke-linejoin="round"/>
                                        </svg>
                                    </span>
                                    </a>

                                    <div class="fast-catalog-list__dropdown">
                                        {% for item in [
                                            'Отделочные материалы техника',
                                            'Мужская одежда',
                                            'Детская одежда',
                                            'Женская одежда',
                                            'Мужская одежда',
                                        ] %}
                                            <a href="" class="fast-catalog-list__link">
                                                <span class="fast-catalog-list__text">
                                                    {{ item }}
                                                </span>
                                            </a>
                                        {% endfor %}
                                    </div>
                                </div>
                            {% endfor %}

                            <button
                                    data-show-text="Еще"
                                    data-hide-text="Скрыть"
                                    class="fast-catalog-list__link is-button js-fast-catalog__show-more"
                            >
                                Еще
                            </button>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}