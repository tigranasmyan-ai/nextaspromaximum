{% embed 'templates/base.twig' with {
    title: 'Главная',
    class: {},
} %}
    {% block content %}
        <section class="section">
            <div class="container section__main">
                {% include '@components/breadcrumbs.twig' with {
                    items: [
                        { text: 'Бренды' }
                    ]
                } %}

                {% set tabs = [
                    {'id': 'SalesPageActiveList', 'label': 'Активные акции', 'active': true, 'disabled': false},
                    {'id': 'SalesPageArchiveList', 'label': 'Архив', 'active': false, 'disabled': false},
                ] %}

                <div class="tabs-head is-scrollable-mobile ">
                    {% for tab in tabs %}
                        <a href="" class="tabs-head__link {% if tab.active %}active{% endif %}">
                            {{ tab.label }}
                        </a>
                    {% endfor %}
                </div>

                <div class="row row-cols-lg-2 row-cols-md-3 row-cols-2 g-md-3 g-2">
                    {% for item in 1..4 %}
                        <div class="col">
                            {% include 'item/sale-item.twig' with {
                                badge: true
                            } %}
                        </div>
                    {% endfor %}
                </div>
            </div>
        </section>
    {% endblock %}
{% endembed %}
