{% extends 'templates/page.twig' %}

{% block title %}Акции - Aspro{% endblock %}

{% block page_title %}Парфюмерия{% endblock %}

{% block page_text %}
    Обратить на себя внимание и показать окружающим чувство вкуса поможет качественный парфюм. Он, как вишенка на торте, сделает законченным любой образ и придаст уверенности в себе. Будьте всегда на высоте с ароматами от популярных брендов!
{% endblock %}

{% block page_content %}
    <div class="container">
        <div class="catalog-page__wrapper">
            <div class="catalog-page__aside">
                <div class="offcanvas offcanvas-start filter-offcanvas" tabindex="-1" id="FilterMobile"
                     aria-labelledby="FilterMobileLabel">
                    <div class="filter">
                        <div class="filter__head">
                            <div class="filter__title title title-h4">Фильтр</div>

                            {% include '../components/ui/close.twig' with {
                                class: 'filter__close',
                                dismiss: 'offcanvas'
                            } %}
                        </div>

                        <div class="filter-item">
                            <a
                                    class="filter-item__head"
                                    data-bs-toggle="collapse"
                                    href="#FilterCategories"
                                    role="button"
                                    aria-expanded="false"
                                    aria-controls="FilterCategories"
                            >
                                <span>Категория</span>

                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16"
                                     fill="none">
                                    <path d="M6 4L9 8L6 12" stroke-width="2" stroke-linecap="round"
                                          stroke-linejoin="round"/>
                                </svg>
                            </a>

                            <div class="collapse show" id="FilterCategories">
                                <div class="filter-item__content">
                                    <div class="filter-catalog">
                                        <a href="" class="filter-catalog__main">
                                            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"
                                                 xmlns="http://www.w3.org/2000/svg">
                                                <path d="M9 4L6 8L9 12" stroke-width="2" stroke-linecap="round"
                                                      stroke-linejoin="round"/>
                                            </svg>

                                            Красота и здоровье
                                        </a>

                                        <nav class="filter-catalog__nav">
                                            {% for item in 1..4 %}
                                                <a href="" class="{{ loop.last ? 'active' : '' }}">Пищевые добавки</a>
                                            {% endfor %}
                                        </nav>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="filter-item">
                            <a
                                    class="filter-item__head collapsed"
                                    data-bs-toggle="collapse"
                                    href="#FilterPriceRange"
                                    role="button"
                                    aria-expanded="false"
                                    aria-controls="FilterPriceRange"
                            >
                                <span>Розничная цена</span>

                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16"
                                     fill="none">
                                    <path d="M6 4L9 8L6 12" stroke-width="2" stroke-linecap="round"
                                          stroke-linejoin="round"/>
                                </svg>
                            </a>

                            <div class="collapse" id="FilterPriceRange">
                                <div class="filter-item__content">
                                    {% include '../components/ui/range-slider.twig' with {
                                        min: 0,
                                        max: 200000,
                                        start_min: 1500,
                                        start_max: 150000,
                                        step: 100
                                    } %}
                                </div>
                            </div>
                        </div>

                        <div class="filter-item">
                            <a
                                    class="filter-item__head collapsed"
                                    data-bs-toggle="collapse"
                                    href="#FilterRadios"
                                    role="button"
                                    aria-expanded="false"
                                    aria-controls="FilterRadios"
                            >
                                <span>Наши предложения</span>

                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16"
                                     fill="none">
                                    <path d="M6 4L9 8L6 12" stroke-width="2" stroke-linecap="round"
                                          stroke-linejoin="round"/>
                                </svg>
                            </a>

                            <div class="collapse" id="FilterRadios">
                                <div class="filter-item__content">
                                    {% include '../components/ui/radio.twig' with { label: 'Все', name: 'stock', value: 'all', checked: true } %}
                                    {% include '../components/ui/radio.twig' with { label: 'В наличии', name: 'stock', value: 'in_stock' } %}
                                    {% include '../components/ui/radio.twig' with { label: 'Под заказ', name: 'stock', value: 'on_order' } %}
                                </div>
                            </div>
                        </div>

                        <div class="filter-item">
                            <a
                                    class="filter-item__head collapsed"
                                    data-bs-toggle="collapse"
                                    href="#FilterCheckboxes"
                                    role="button"
                                    aria-expanded="false"
                                    aria-controls="FilterCheckboxes"
                            >
                                <span>Дополнительно</span>

                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16"
                                     fill="none">
                                    <path d="M6 4L9 8L6 12" stroke-width="2" stroke-linecap="round"
                                          stroke-linejoin="round"/>
                                </svg>
                            </a>

                            <div class="collapse" id="FilterCheckboxes">
                                <div class="filter-item__content">
                                    {% include '../components/ui/checkbox.twig' with { label: 'Хит', id: 'prop-hit' } %}
                                    {% include '../components/ui/checkbox.twig' with { label: 'Новинка', id: 'prop-new', checked: true } %}
                                    {% include '../components/ui/checkbox.twig' with { label: 'Акция', id: 'prop-sale' } %}
                                    {% include '../components/ui/checkbox.twig' with { label: 'Акция', id: 'prop-sale' } %}
                                    {% include '../components/ui/checkbox.twig' with { label: 'Акция', id: 'prop-sale' } %}
                                    {% include '../components/ui/checkbox.twig' with { label: 'Акция', id: 'prop-sale' } %}
                                    {% include '../components/ui/checkbox.twig' with { label: 'Акция', id: 'prop-sale' } %}
                                    {% include '../components/ui/checkbox.twig' with { label: 'Акция', id: 'prop-sale' } %}
                                    {% include '../components/ui/checkbox.twig' with { label: 'Акция', id: 'prop-sale' } %}
                                    {% include '../components/ui/checkbox.twig' with { label: 'Акция', id: 'prop-sale' } %}
                                    {% include '../components/ui/checkbox.twig' with { label: 'Акция', id: 'prop-sale' } %}
                                </div>
                            </div>
                        </div>

                        <div class="filter-item">
                            <div class="filter-item__head is-single">
                                <span>Наличие</span>

                                {% include '../components/ui/switch.twig' with { id: 'extra-photo', checked: true } %}
                            </div>
                        </div>

                        <div class="filter__bottom">
                            <button data-bs-dismiss="offcanvas" aria-label="Close" class="filter__button is-reset button button-block button-transparent-bg button-lg">
                                Сбросить
                            </button>

                            <button data-bs-dismiss="offcanvas" aria-label="Close" class="filter__button is-apply button button-block button-default button-lg">
                                Показать
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="catalog-page__content">
                <div>
                    <a href="" data-bs-toggle="offcanvas" data-bs-target="#FilterMobile"
                       aria-controls="FilterMobileExample">
                        asd
                    </a>
                </div>

                <div>
                    <div class="row g-md-3 g-3">
                        {% for item in 1..3 %}
                            <div class="col-xl-4 col-6">
                                {% include '../components/shop/product.twig' %}
                            </div>
                        {% endfor %}
                    </div>

                    <br>
                    <br>
                    <br>

                    <div class="row g-md-3 g-3">
                        {% for item in 1..4 %}
                            <div class="col-xl-3 col-6">
                                {% include '../components/shop/product.twig' %}
                            </div>
                        {% endfor %}
                    </div>

                    <br>
                    <br>
                    <br>

                    <div class="product-card-list">
                        <div class="row g-md-0 g-sm-2 g-0">
                            {% for item in 1..6 %}
                                <div class="col-md-12 col-6 product-card-list__col">
                                    {% include '../components/shop/product-list.twig' %}
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                </div>

                <div class="text-content">
                    <p>
                        Если появились вопросы по нюансам покупки, пишите в наш онлайн-чат. Подберем идеальный для вас
                        вариант, сориентируем по способам оплаты и рассчитаем стоимость доставки.
                    </p>

                    <p>
                        Если появились вопросы по нюансам покупки, пишите в наш онлайн-чат. Подберем идеальный для вас
                        вариант, сориентируем по способам оплаты и рассчитаем стоимость доставки.
                    </p>

                    <p>
                        Если появились вопросы по нюансам покупки, пишите в наш онлайн-чат. Подберем идеальный для вас
                        вариант, сориентируем по способам оплаты и рассчитаем стоимость доставки.
                    </p>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block page_other_sections %}
    <div class="container section">
        <div class="section__main">
            <h3 class="title title-h3">Вы смотрели</h3>

            <div class="swiper js-products-view-slider">
                <div class="swiper-wrapper">
                    {% for item in 1..10 %}
                        <div class="swiper-slide">
                            {% include '../components/shop/product-view.twig' with {
                                badge: { text: '-10%', type: 'red' }
                            } %}
                        </div>
                    {% endfor %}
                </div>

                <div class="swiper-button-next swiper-arrow"></div>
                <div class="swiper-button-prev swiper-arrow"></div>
            </div>
        </div>
    </div>
{% endblock %}