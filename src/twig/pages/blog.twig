{% embed 'templates/base.twig' with {
    title: 'Главная',
    class: {},
} %}
    {% block content %}
        <section class="section">
            <div class="container section__main">
                {% include '@components/breadcrumbs.twig' with {
                    items: [
                        { text: 'Бренды' }
                    ]
                } %}

                <div class="section__head">
                    <div class="title title-h1">Блог</div>
                </div>

                <div class="blog-page__top">
                    <div class="tabs-head is-scrollable-mobile">
                        {% set tabs = [
                            { id: 'popular', label: 'Популярные', active: true },
                            { id: 'new', label: 'Новинки' },
                            { id: 'sale', label: 'Акции' }
                        ] %}

                        {% for tab in tabs %}
                            <a href="" class="tabs-head__link {% if tab.active %}active{% endif %}">
                                {{ tab.label }}
                            </a>
                        {% endfor %}
                    </div>

                    <a class="blog-page__tags-link" data-bs-toggle="collapse" href="#BlogPageTags" role="button"
                       aria-expanded="false" aria-controls="BlogPageTags">
                        Теги
                    </a>
                </div>

                <div class="collapse" id="BlogPageTags">
                    <div class="blog-page__tags">
                        {% for item in 1..15 %}
                            <div>
                                <a href="" class="button button-sm button-solid">
                                    Тег {{ loop.index }}
                                </a>
                            </div>
                        {% endfor %}
                    </div>
                </div>

                <div class="row gx-3 gy-4">
                    {% for item in 1..9 %}
                        <div class="col-lg-3 col-md-6">
                            {% include 'item/post/post-item-grid.twig' with {
                                post_solid: true
                            } %}
                        </div>
                    {% endfor %}
                </div>
            </div>
        </section>
    {% endblock %}
{% endembed %}