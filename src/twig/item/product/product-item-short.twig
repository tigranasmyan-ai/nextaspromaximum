<div class="product-item-short">
    <button type="button" class="product-item-short__remove">
        <svg width="18" height="18">
            <use xlink:href="img/svg-icons.svg#remove"></use>
        </svg>
    </button>

    <a href="">
        <picture class="product-item-short__picture">
            <img src="https://premier-demo.ru/upload/resize_cache/iblock/c28/64_64_1/uw5p61iophgtnli7sok77hrmswpg2924.jpg"
                 alt=""
                 class="product-item-short__img"
            >
        </picture>
    </a>

    <div class="product-item-short__info">
        {% if cart %}
            {% include '@components/@shop/price.twig' with {
                class: 'product-item-short__price',
                size: 'md',
                now: '600 ₽',
                old: '300 ₽'
            } %}

            {% include '@components/@shop/price.twig' %}
        {% endif %}

        <a href="" class="product-item-short__name">
            Набор для создания свечи
        </a>
    </div>
</div>