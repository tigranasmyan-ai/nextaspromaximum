<div class="catalog-item">
    <img src="https://premier-demo.ru/upload/resize_cache/iblock/79e/108_108_0/wuy5uh0kcnk6gcgcwkz5l2w41rvmk4h5.jpg"
         class="catalog-item__img" alt="">

    <div>
        <a href="" class="catalog-item__title">Смартфоны</a>

        <div class="catalog-item__links js-catalog-item__list">
            {% for item in [
                'Отделочные материалы техника',
                'Мужская',
                'Детская',
                'Женская',
                'Мужская',
                'Мужская',
                'Детская',
                'Женская',
                'Мужская',
            ] %}
                <div>
                    <a href="" class="catalog-item__link catalog-item-link js-catalog-item__link">
                        <span class="catalog-item-link__text">
                            {{ item }}
                        </span>

                        <span class="catalog-item-link__icon js-catalog-item__show-more-submenu">
                            <svg xmlns="http://www.w3.org/2000/svg" width="8" height="5" viewBox="0 0 8 5" fill="none">
                                <path d="M7 1L4 4L1 1" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </span>
                    </a>

                    <div class="catalog-item__dropdown">
                        {% for item in [
                            'Отделочные материалы техника',
                            'Мужская',
                            'Детская',
                            'Женская',
                            'Мужская',
                        ] %}
                            <a href="" class="catalog-item__link catalog-item-link">
                                <span class="catalog-item-link__text">
                                    {{ item }}
                                </span>
                            </a>
                        {% endfor %}
                    </div>
                </div>
            {% endfor %}

            <button
                    data-show-text="Еще"
                    data-hide-text="Скрыть"
                    class="catalog-item__more is-button js-catalog-item__show-more"
            >
                Еще
            </button>
        </div>
    </div>
</div>