<div class="range-slider js-range-slider" 
     data-min="{{ min|default(0) }}" 
     data-max="{{ max|default(10000) }}" 
     data-start-min="{{ start_min|default(min|default(0)) }}" 
     data-start-max="{{ start_max|default(max|default(10000)) }}"
     data-step="{{ step|default(0.01) }}">
    
    <div class="range-slider__inputs">
        <div class="range-slider__field">
            <input type="text" class="range-slider__input js-range-slider__input-min" value="{{ start_min|default(min|default(0)) }}">
        </div>
        <div class="range-slider__field">
            <input type="text" class="range-slider__input js-range-slider__input-max" value="{{ start_max|default(max|default(10000)) }}">
        </div>
    </div>

    <div class="range-slider__element js-range-slider__element"></div>
</div>
