{% extends 'templates/modal.twig' %}

{% block id %}CallbackModal{% endblock %}

{% block content %}

    <div>
        <div class="title-h3 title">Заказать звонок</div>
        <div class="modal__text">Представьтесь, мы вам перезвоним.</div>
    </div>

    <form class="js-validation-form">
        {% include '@components/forms/input.twig' with {
            label: 'Ваше имя *',
            type: 'email',
            id: 'CallbackModalEmail',
            required: true
        } %}

        {% include '@components/forms/input.twig' with {
            label: 'Телефон *',
            type: 'text',
            id: 'CallbackModalPhone',
            required: true,
            class: 'phone'
        } %}

        {% include '@components/forms/input.twig' with {
            label: 'Пароль (для проверки)',
            type: 'password',
            id: 'CallbackModalPassword',
            name: 'password',
            required: true
        } %}

        <div class="form-group">
            {% include '@components/forms/checkbox.twig' with {
                label: 'Я согласен(а) с условиями обработки персональных данных',
                id: 'CallbackModalAgreement',
                name: 'agreement',
                required: true,
                checked: true
            } %}
        </div>

        <button type="submit" class="button button-default button-block button-lg">
            Отправить
        </button>
    </form>

{% endblock %}

