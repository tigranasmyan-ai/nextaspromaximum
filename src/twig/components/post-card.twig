<div class="post-card {{ class }} {{ single_type ? 'post-card--solid' : '' }}">
    {% include 'components/ui/badge.twig' with {
        text: 'текст',
        type: 'dark-opacity',
        class: 'post-card__badge',
        tag: 'div'
    } %}

    <div class="post-card__picture">
        <img src="https://premier-demo.ru/upload/iblock/c3d/os6fn6gr7erb2gdk1zioizm8ti4rysvw.jpg" alt="{{ title }}">
    </div>

    <div class="post-card__content">
        <span class="post-card__title title title-h6">
            Здоровое питание без глютена: как выбрать и приготовить?
        </span>

        <div class="post-card__date">
            11 мая 2024
        </div>
    </div>

    <a href="blog-single.html" class="post-card__link"></a>
</div>
