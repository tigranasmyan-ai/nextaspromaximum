{% set actions = [
    { href: '', icon: 'log-out', text: 'Войти', width: 18, height: 18 },
    { href: '', icon: 'compare', text: 'Сравнение', width: 20, height: 20 },
    { href: '', icon: 'favorite', text: 'Избранное', width: 20, height: 20 },
    { href: '', icon: 'cart', text: 'Корзина', width: 20, height: 20 }
] %}

{% set menus = [
    { href: '', text: 'Акции', id: 'services', sub_menu: true },
    { href: '', text: 'Блог', id: 'blog', sub_menu: true },
    { href: '', text: 'Товары', id: 'products', sub_menu: false }
] %}

<div class="offcanvas offcanvas-start fixed-bar" tabindex="-1" id="LeftMenu" aria-labelledby="LeftMenu">
    <button type="button" class="fixed-bar__close" data-bs-dismiss="offcanvas" aria-label="Close">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16">
            <path fill-rule="evenodd" clip-rule="evenodd" d="M0.292893 0.292893C0.683417 -0.0976311 1.31658 -0.0976311 1.70711 0.292893L8 6.58579L14.2929 0.292893C14.6834 -0.0976311 15.3166 -0.0976311 15.7071 0.292893C16.0976 0.683417 16.0976 1.31658 15.7071 1.70711L9.41421 8L15.7071 14.2929C16.0976 14.6834 16.0976 15.3166 15.7071 15.7071C15.3166 16.0976 14.6834 16.0976 14.2929 15.7071L8 9.41421L1.70711 15.7071C1.31658 16.0976 0.683417 16.0976 0.292893 15.7071C-0.0976311 15.3166 -0.0976311 14.6834 0.292893 14.2929L6.58579 8L0.292893 1.70711C-0.0976311 1.31658 -0.0976311 0.683417 0.292893 0.292893Z"/>
        </svg>
    </button>

    <div class="fixed-bar__slide">
        <div class="fixed-bar__content">
            <div class="fixed-bar__location fixed-bar-location">
                <svg class="fixed-bar-location__icon">
                    <use xlink:href="img/svg-icons-final.svg#region"></use>
                </svg>

                <span class="fixed-bar-location__value">
                        Челябинск
                    </span>
            </div>

            <div class="fixed-bar__catalog">
                <a href="" class="button button-default button-lg button-block js-fixed-bar-menu__link">
                    Каталог
                </a>

                <ul class="fixed-bar-menu__sub-menu">
                    {% set catalog_items = [
                        { text: 'Строительные материалы', sub: ['Кирпич', 'Бетон', 'Арматура'] },
                        { text: 'Инструменты', sub: ['Электроинструмент', 'Ручной инструмент'] },
                        { text: 'Сантехника', sub: ['Смесители', 'Раковины', 'Ванны'] },
                        { text: 'Электрика', sub: ['Кабель', 'Розетки', 'Освещение'] }
                    ] %}

                    {% for item in catalog_items %}
                        <li>
                            <a href="" class="fixed-bar-menu__link js-fixed-bar-menu__link">
                                {{ item.text }}
                                <span class="fixed-bar-menu__chevron">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 3 5">
                                        <path d="M2.98043e-07 5L3 2.50006L0 3.57746e-08L2.98043e-07 5Z"/>
                                    </svg>
                                </span>
                            </a>

                            <ul class="fixed-bar-menu__sub-menu">
                                {% for sub in item.sub %}
                                    <li>
                                        <a href="" class="fixed-bar-menu__link js-fixed-bar-menu__link">
                                            {{ sub }}
                                        </a>
                                    </li>
                                {% endfor %}
                            </ul>
                        </li>
                    {% endfor %}
                </ul>
            </div>

            <div class="fixed-bar__col">
                <div class="fixed-bar-actions">
                    {% for action in actions %}
                        <a href="{{ action.href }}" class="fixed-bar-action">
                            <svg class="fixed-bar-action__icon" width="{{ action.width }}"
                                 height="{{ action.height }}">
                                <use href="img/svg-icons-final.svg#{{ action.icon }}"></use>
                            </svg>

                            <span class="fixed-bar-action__text">{{ action.text }}</span>

                            {% if loop.index != 1 %}
                                <span class="fixed-bar-action__counter">12834</span>
                            {% endif %}
                        </a>
                    {% endfor %}
                </div>
            </div>

            <span class="fixed-bar__divider"></span>

            <div class="fixed-bar__col">
                <ul class="fixed-bar-menu">
                    {% set simulation_menu = [
                        { text: 'Бренды', sub: false },
                        { text: 'Акции', sub: false },
                        { text: 'Конаткны', sub: false },
                        { text: 'Каталог товаров', sub: [
                            { text: 'Электроника', sub: ['Смартфоны', 'Ноутбуки', 'Телевизоры'] },
                            { text: 'Одежда', sub: ['Мужская', 'Женская', 'Детская'] },
                            { text: 'Дом и сад', sub: ['Мебель', 'Декор', 'Инструменты'] }
                        ]},
                        { text: 'Услуги компании', sub: [
                            { text: 'Доставка', sub: ['Курьером', 'В пункт выдачи', 'Почтой'] },
                            { text: 'Монтаж', sub: ['Установка техники', 'Сборка мебели'] },
                            { text: 'Сервис', sub: ['Гарантия', 'Ремонт'] }
                        ]},
                        { text: 'Акции и скидки', sub: false }
                    ] %}

                    {% for item in simulation_menu %}
                        <li>
                            <a href="" class="fixed-bar-menu__link js-fixed-bar-menu__link">
                                {{ item.text }}
                                {% if item.sub %}
                                    <span class="fixed-bar-menu__chevron">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 3 5">
                                            <path d="M2.98043e-07 5L3 2.50006L0 3.57746e-08L2.98043e-07 5Z"/>
                                        </svg>
                                    </span>
                                {% endif %}
                            </a>

                            {% if item.sub %}
                                <ul class="fixed-bar-menu__sub-menu">
                                    {% for sub1 in item.sub %}
                                        <li>
                                            <a href="" class="js-fixed-bar-menu__link fixed-bar-menu__link">
                                                {{ sub1.text|default(sub1) }}
                                                {% if sub1.sub is defined and sub1.sub %}
                                                    <span class="fixed-bar-menu__chevron">
                                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 3 5">
                                                            <path d="M2.98043e-07 5L3 2.50006L0 3.57746e-08L2.98043e-07 5Z"/>
                                                        </svg>
                                                    </span>
                                                {% endif %}
                                            </a>

                                            {% if sub1.sub is defined and sub1.sub %}
                                                <ul class="fixed-bar-menu__sub-menu">
                                                    {% for sub2 in sub1.sub %}
                                                        <li>
                                                            <a href="" class="js-fixed-bar-menu__link fixed-bar-menu__link">
                                                                {{ sub2 }}
                                                            </a>
                                                        </li>
                                                    {% endfor %}
                                                </ul>
                                            {% endif %}
                                        </li>
                                    {% endfor %}
                                </ul>
                            {% endif %}
                        </li>
                    {% endfor %}
                </ul>
            </div>

            <span class="fixed-bar__divider"></span>

            <div class="fixed-bar__col is-indent">
                <a href="" class="fixed-bar-phone">
                    <span>
                        <span class="fixed-bar-phone__value">
                             +7 100 000-00-00
                        </span>

                        <span class="fixed-bar-phone__label">
                            Бухгалтерия
                        </span>
                    </span>

                    <svg class="fixed-bar-phone__chevron">
                        <use href="img/svg-icons-final.svg#down"></use>
                    </svg>
                </a>
            </div>

            <div class="fixed-bar__col is-indent">
                <div class="fixed-bar__contacts">
                    <a href="" class="fixed-bar__contact">
                        no-reply@chel.premier-demo.ru
                    </a>

                    <span class="fixed-bar__contact">
                        Челябинск, ул. Лермонтова 21, <br> 3 этаж, офис 4
                    </span>

                    <span class="fixed-bar__contact">
                        Пн - Вс: 11.00 - 19.00
                    </span>
                </div>
            </div>

            <div class="fixed-bar__col is-indent">
                <div class="contacts-widget__socials">
                    <a href="" class="contacts-widget__social-item contacts-widget__social-item--viber" aria-label="Viber"></a>
                    <a href="" class="contacts-widget__social-item contacts-widget__social-item--vkontakte" aria-label="VKontakte"></a>
                </div>
            </div>

            <span class="fixed-bar__divider"></span>

            <div class="fixed-bar__col is-indent">
                asd
            </div>
        </div>
    </div>
</div>